{
  "name": "@elpapi42/pi-fleet",
  "version": "0.0.0-development",
  "private": true,
  "description": "A local runtime and machine-first CLI for named Pi agents",
  "type": "module",
  "engines": {
    "node": "^22.19.0 || ^24.0.0"
  },
  "bin": {
    "pifleet": "./bin/pifleet.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts bin --max-warnings=0",
    "format:check": "prettier --check .",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:integration": "vitest run test/integration --maxWorkers=1",
    "test:process": "vitest run test/process --maxWorkers=1",
    "test:package": "npm run build && vitest run test/package --maxWorkers=1",
    "test:platform": "vitest run test/integration/service-installer.test.ts test/process/process-tree.test.ts --maxWorkers=1",
    "test:compat": "vitest run test/compat --maxWorkers=1",
    "probe:pi": "node scripts/pi-compatibility-probe.mts",
    "benchmark:store": "npm run build && vitest run --config vitest.benchmark.config.ts",
    "build": "node scripts/build.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "22.19.1",
    "esbuild": "0.25.11",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@sinclair/typebox": "0.34.52",
    "commander": "15.0.0"
  }
}
